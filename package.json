{
  "name": "favour-of-olympus",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "dev": "pnpm --parallel --filter @favour-of-olympus/client --filter @favour-of-olympus/server dev",
    "test": "pnpm --recursive --if-present test",
    "typecheck": "pnpm --recursive --if-present typecheck"
  },
  "devDependencies": {
    "typescript": "latest",
    "vitest": "latest"
  }
}
