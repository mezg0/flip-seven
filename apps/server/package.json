{
  "name": "@favour-of-olympus/server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/main.ts --format esm --clean",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@favour-of-olympus/game": "workspace:*",
    "@favour-of-olympus/protocol": "workspace:*",
    "effect": "catalog:",
    "socket.io": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "tsup": "latest",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
